    "db:studio": "drizzle-kit studio",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@nestjs/cli": "11.0.21",
    "@nestjs/core": "11.1.19",
    "drizzle-orm": "^0.45.2",
    "next": "15.5.15"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.7.3"
  }
