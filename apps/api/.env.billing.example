# ─── Razorpay Keys ──────────────────────────────────────────────────────────
# Get from Razorpay Dashboard → Settings → API Keys

# Test keys (used when NODE_ENV !== 'production')
RAZORPAY_KEY_ID_TEST=rzp_test_REPLACE_ME
RAZORPAY_KEY_SECRET_TEST=REPLACE_ME

# Live keys (used when NODE_ENV === 'production')
RAZORPAY_KEY_ID_LIVE=rzp_live_REPLACE_ME
RAZORPAY_KEY_SECRET_LIVE=REPLACE_ME

# Webhook secret — from Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=REPLACE_ME

# ─── Razorpay Plan IDs ──────────────────────────────────────────────────────
# Create plans in Razorpay Dashboard → Subscriptions → Plans
# Pro monthly: ₹499 / month
RAZORPAY_PLAN_PRO_MONTHLY=plan_REPLACE_ME
# Pro yearly: ₹4,499 / year
RAZORPAY_PLAN_PRO_YEARLY=plan_REPLACE_ME
# Elite monthly: ₹999 / month
RAZORPAY_PLAN_ELITE_MONTHLY=plan_REPLACE_ME
# Elite yearly: ₹8,999 / year
RAZORPAY_PLAN_ELITE_YEARLY=plan_REPLACE_ME

# ─── Existing env vars (reminder) ───────────────────────────────────────────
# DATABASE_URL=postgresql://...
# CLERK_SECRET_KEY=sk_...
# OPENAI_API_KEY=sk-...
# ENCRYPTION_KEY=<32-byte hex — use: openssl rand -hex 32>
# UPSTASH_REDIS_URL=rediss://...
# UPSTASH_REDIS_TOKEN=...
# ALLOWED_ORIGINS=http://localhost:3000,https://tradeforge.in
# PORT=4000
