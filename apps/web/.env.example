# ─── Server Configuration ─────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ─── Database & Storage ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Cloudflare R2
CLOUDFLARE_R2_ACCESS_KEY=
CLOUDFLARE_R2_SECRET=
CLOUDFLARE_R2_ENDPOINT=https://ACCOUNT_ID.r2.cloudflarestorage.com
CLOUDFLARE_R2_BUCKET=thirdleaf

# Redis (Upstash)
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ─── Security & Authentication ────────────────────────────────────────────────
ENCRYPTION_KEY= # 32-byte hex string (64 characters)
JWT_SECRET=
CLIENT_PORTAL_JWT_SECRET=
ADMIN_EMAILS=admin@example.com

# Clerk (Backend)
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Clerk (Frontend)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# ─── Billing (Razorpay) ───────────────────────────────────────────────────────
# API Keys
RAZORPAY_KEY_ID_TEST=
RAZORPAY_KEY_SECRET_TEST=
RAZORPAY_KEY_ID_LIVE=
RAZORPAY_KEY_SECRET_LIVE=
RAZORPAY_WEBHOOK_SECRET=

# Plan IDs
RAZORPAY_PLAN_PRO_MONTHLY=
RAZORPAY_PLAN_PRO_YEARLY=
RAZORPAY_PLAN_ELITE_MONTHLY=
RAZORPAY_PLAN_ELITE_YEARLY=

# ─── AI Coach ─────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─── Frontend Configuration ───────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# Monitoring
SENTRY_DSN=
